# Minimal Linux kernel fragment for the BBLinux RV32 emulator.
# Target: single-core, serial-only, no virtio/PCI/network, low debug overhead.
#
# Use this as a config fragment to merge into your Buildroot Linux kernel config.
# It is intentionally conservative: some symbols may be absent on your exact
# kernel version, but the fragment is still useful as a baseline.

# CPU / platform
CONFIG_SMP=n
CONFIG_NR_CPUS=1

# Keep the ISA/features close to the emulator
CONFIG_FPU=n
CONFIG_RISCV_ISA_FALLBACK=y

# Modules
CONFIG_MODULES=n

# Reduce debug / hardening overhead during bring-up
CONFIG_STACKPROTECTOR=n
CONFIG_STACKPROTECTOR_STRONG=n
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_MAGIC_SYSRQ=n
CONFIG_KALLSYMS=n
CONFIG_FTRACE=n
CONFIG_FUNCTION_TRACER=n
CONFIG_DYNAMIC_DEBUG=n
CONFIG_LOCKDEP=n
CONFIG_PROVE_LOCKING=n
CONFIG_DEBUG_SPINLOCK=n
CONFIG_DEBUG_MUTEXES=n
CONFIG_DEBUG_ATOMIC_SLEEP=n
CONFIG_SCHED_DEBUG=n
CONFIG_TRACE_IRQFLAGS=n
CONFIG_SOFTLOCKUP_DETECTOR=n
CONFIG_DETECT_HUNG_TASK=n
CONFIG_WQ_WATCHDOG=n
CONFIG_KGDB=n
CONFIG_KDB=n
CONFIG_UBSAN=n
CONFIG_KASAN=n
CONFIG_KCSAN=n
CONFIG_KFENCE=n

# Keep console output lighter
CONFIG_PRINTK_TIME=n

# Buses / devices you do not emulate
CONFIG_PCI=n
CONFIG_PCI_DOMAINS=n
CONFIG_VIRTIO_MENU=n
CONFIG_VIRTIO_MMIO=n
CONFIG_FW_CFG_SYSFS=n

# Networking off
CONFIG_NET=n
CONFIG_INET=n

# Storage / block stack off unless you later add a real block device
CONFIG_BLOCK=n
CONFIG_BLK_DEV=n
CONFIG_SCSI=n
CONFIG_ATA=n
CONFIG_MMC=n

# Input / multimedia / graphics / USB off
CONFIG_INPUT=n
CONFIG_SOUND=n
CONFIG_HID=n
CONFIG_USB_SUPPORT=n
CONFIG_USB=n
CONFIG_DRM=n
CONFIG_FB=n
CONFIG_BACKLIGHT_CLASS_DEVICE=n
CONFIG_FRAMEBUFFER_CONSOLE=n

# Random peripheral buses off
CONFIG_I2C=n
CONFIG_SPI=n
CONFIG_GPIOLIB=n
CONFIG_W1=n
CONFIG_HWMON=n
CONFIG_THERMAL=n
CONFIG_WATCHDOG=n
CONFIG_LEDS_CLASS=n
CONFIG_RTC_CLASS=n

# Serial console: keep this
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=1
CONFIG_SERIAL_8250_RUNTIME_UARTS=1

# Filesystems: keep only the basics for a tiny userspace / initramfs setup
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=n
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

CONFIG_EXT4_FS=n
CONFIG_EXT2_FS=n
CONFIG_FAT_FS=n
CONFIG_VFAT_FS=n
CONFIG_MSDOS_FS=n
CONFIG_SQUASHFS=n
CONFIG_NFS_FS=n
CONFIG_FUSE_FS=n

# Namespaces / cgroups / misc features off for a tiny kernel
CONFIG_CGROUPS=n
CONFIG_NAMESPACES=n
CONFIG_BPF_SYSCALL=n
CONFIG_AUDIT=n
CONFIG_SWAP=n
CONFIG_BLK_DEV_INITRD=y
